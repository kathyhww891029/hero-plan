{
  "rules": {
    "pending": {
      ".read": true,
      ".write": "auth != null && ((!data.exists() && newData.hasChildren(['type', 'taskId', 'name', 'score', 'date', 'submittedAt'])) || newData.val() === null)",
      "$key": {
        ".write": "auth != null && (!data.exists() || newData.val() === null || (newData.hasChildren(['isSelf', 'status']) && data.child('status').val() !== 'approved'))"
      }
    },
    "approved": {
      ".read": true,
      ".write": false
    },
    "totalScore": {
      ".read": true,
      ".write": false
    },
    "weeklyScore": {
      ".read": true,
      ".write": false
    },
    "characterRecords": {
      ".read": true,
      ".write": false
    },
    "ropeRecords": {
      ".read": true,
      ".write": false
    },
    "homeworkRecords": {
      ".read": true,
      ".write": false
    },
    "focusRecords": {
      ".read": true,
      ".write": false
    },
    "syncScore": {
      ".read": true,
      ".write": "auth != null"
    },
    "reviewed": {
      ".read": true,
      ".write": "auth != null"
    }
  }
}
